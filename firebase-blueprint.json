{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "mainResumeText": { "type": "string" },
        "mainResumeName": { "type": "string" },
        "walletBalance": { "type": "number" },
        "premiumUntil": { "type": "string", "format": "date-time" },
        "isBanned": { "type": "boolean" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ResumeHistory": {
      "title": "ResumeHistory",
      "description": "A record of a tailored resume generated by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "resumeText": { "type": "string" },
        "atsScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "resumeText", "createdAt"]
    },
    "WalletTransaction": {
      "title": "WalletTransaction",
      "description": "A record of a wallet top-up or deduction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["topup", "deduction", "subscription", "admin_add", "admin_deduct"] },
        "reason": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "createdAt"]
    },
    "JobRecord": {
      "title": "JobRecord",
      "description": "A job application tracked by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "jobLink": { "type": "string" },
        "dateApplied": { "type": "string" },
        "location": { "type": "string" },
        "workMode": { "type": "string" },
        "salary": { "type": "string" },
        "skillsRequired": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "jobDescriptionSnapshot": { "type": "string" },
        "keywordsExtracted": { "type": "array", "items": { "type": "string" } },
        "atsMatchScore": { "type": "number" },
        "interviewPrepId": { "type": "string" },
        "tailoredResumeResult": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "company", "role", "status", "createdAt", "updatedAt"]
    },
    "InterviewPrepModule": {
      "title": "InterviewPrepModule",
      "description": "An AI-generated interview prep module for a specific job.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "companyName": { "type": "string" },
        "roleName": { "type": "string" },
        "dateCreated": { "type": "string", "format": "date-time" },
        "hrQuestions": { "type": "array" },
        "technicalQuestions": { "type": "array" },
        "assessmentPrep": { "type": "array" },
        "companyPrep": { "type": "object" },
        "resumeQuestions": { "type": "array" },
        "aceThisJob": { "type": "object" }
      },
      "required": ["id", "userId", "jobId", "companyName", "roleName", "dateCreated"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A user's subscription status.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "canceled", "expired"] },
        "planId": { "type": "string" },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "razorpayCustomerId": { "type": "string" },
        "razorpaySubscriptionId": { "type": "string" }
      },
      "required": ["userId", "status", "currentPeriodEnd"]
    },
    "OneTimePayment": {
      "title": "OneTimePayment",
      "description": "A one-time payment for a resume download.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "resumeId": { "type": "string" },
        "status": { "type": "string", "enum": ["succeeded", "pending", "failed"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "razorpayOrderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "resumeId", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user's feedback or review of the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhoto": { "type": "string" },
        "message": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/JobRecord" },
      "description": "Stores job applications."
    },
    "/interviewPreps/{prepId}": {
      "schema": { "$ref": "#/entities/InterviewPrepModule" },
      "description": "Stores interview prep modules."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "#/entities/Subscription" },
      "description": "Stores user subscriptions."
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/OneTimePayment" },
      "description": "Stores one-time payments."
    },
    "/resumeHistory/{historyId}": {
      "schema": { "$ref": "#/entities/ResumeHistory" },
      "description": "Stores tailored resume history."
    },
    "/wallet_transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/WalletTransaction" },
      "description": "Stores wallet transaction history."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores user feedback and reviews."
    }
  }
}
